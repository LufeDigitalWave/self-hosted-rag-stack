# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=rag
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=rag_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# Cache query results for N seconds (0 = disabled)
CACHE_TTL_SECONDS=300

# ── Embedder ───────────────────────────────────────────────────────────────────
EMBEDDER_URL=http://embedder:8001

# Choose your model. Larger = better quality; smaller = less RAM & faster startup.
#   BAAI/bge-m3                         1.1 GB  best quality, multilingual
#   all-MiniLM-L6-v2                     90 MB  fast, English-only
#   paraphrase-multilingual-mpnet-base-v2 1 GB  good multilingual alternative
MODEL_NAME=BAAI/bge-m3

# Must match the actual output dimension of the chosen model
EMBEDDING_DIM=768

# ── Chunking ───────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ── OpenAI (optional — only needed for the generation / answer step) ───────────
# Leave blank to skip LLM-assisted answer synthesis and return raw chunks only.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
