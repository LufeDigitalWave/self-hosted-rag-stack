se.if","typeVersion":2.3,"position":[-4672,2048],"id":"f1cb7259-8a4e-4a09-8f7a-3cb5ccec848b","name":"If"},{"parameters":{"method":"POST","url":"https://crm.rdstation.com/api/v1/contacts","sendQuery":true,"queryParameters":{"parameters":[{"name":"token","value":"6920bae895b2d4001dadd1a9"}]},"sendHeaders":true,"headerParameters":{"parameters":[{"name":"accept","value":"application/json"}]},"sendBody":true,"bodyParameters":{"parameters":[{"name":"name","value":"={{ $('When Executed by Another Workflow').item.json.Nome }}"},{"name":"phones","value":"={{ $('Merge').item.json.Telefone }}"}]},"options":{}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[-4448,2048],"id":"768af712-7a7d-4817-a42f-95220e6649be","name":"Criar contato14","retryOnFail":true,"waitBetweenTries":5000,"disabled":true},{"parameters":{"jsCode":"const data = $input.first().json;\n\n// ========================\n// TAGS VÁLIDAS\n// ========================\nconst TAGS_QUALIFICACAO = [\n  'alta_qualificacao',\n  'media_qualificacao',\n  'baixa_qualificacao'\n];\n\nconst TAGS_NAVIO = [\n  'embaixador',\n  'embaixador_10-12-2025',\n  'vumbora_promar',\n  'cabare',\n  'rockboat',\n  'reveillon',\n  'chex',\n  'dominguinho',\n  'roberto_carlos',\n  'daniel',\n  'wesley_safadao'\n];\n\n// ========================\n// FUNÇÃO DE NORMALIZAÇÃO\n// ========================\nfunction normalizarTexto(valor) {\n  return String(valor || '')\n    .trim()\n    .toLowerCase()\n    .normalize('NFD')\n    .replace(/[\\u0300-\\u036f]/g, '');\n}\n\n// ========================\n// PEGA A QUALIFICAÇÃO BRUTA\n// ========================\n// tenta em vários lugares possíveis\nconst qualificacaoBruta =\n  data.etiqueta ||\n  data.qualificacao ||\n  data.label ||\n  data.payload?.custom_attributes?.qualificao ||\n  data.meta?.sender?.custom_attributes?.qualificao ||\n  data.custom_attributes?.qualificao ||\n  null;\n\n// ========================\n// MAPEIA BAIXA/MEDIA/ALTA\n// PARA TAG FINAL\n// ========================\nconst qualificacaoNormalizada = normalizarTexto(qualificacaoBruta);\n\nlet novaQualificacao = null;\n\nif (qualificacaoNormalizada === 'baixa' || qualificacaoNormalizada === 'baixa_qualificacao') {\n  novaQualificacao = 'baixa_qualificacao';\n} else if (qualificacaoNormalizada === 'media' || qualificacaoNormalizada === 'media_qualificacao') {\n  novaQualificacao = 'media_qualificacao';\n} else if (qualificacaoNormalizada === 'alta' || qualificacaoNormalizada === 'alta_qualificacao') {\n  novaQualificacao = 'alta_qualificacao';\n}\n\n// ========================\n// VALIDA\n// ========================\nif (!novaQualificacao || !TAGS_QUALIFICACAO.includes(novaQualificacao)) {\n  throw new Error(`Qualificação inválida: ${qualificacaoBruta}`);\n}\n\n// ========================\n// PEGA LABELS ATUAIS\n// ========================\nconst labelsAtuais = Array.isArray(data.labels) ? data.labels : [];\n\n// ========================\n// LIMPA LABELS\n// ========================\nconst labelsLimpas = labelsAtuais\n  .filter(label => typeof label === 'string' && label.trim() !== '')\n  .map(label => label.trim());\n\n// ========================\n// PEGA CAMPANHA/NAVIO\n// ========================\nconst campanha =\n  data.meta?.sender?.custom_attributes?.campanha ||\n  data.payload?.custom_attributes?.campanha ||\n  data.custom_attributes?.campanha ||\n  null;\n\n// ========================\n// REMOVE SÓ QUALIFICAÇÃO ANTIGA\n// ========================\nconst labelsSemQualificacao = labelsLimpas.filter(\n  label => !TAGS_QUALIFICACAO.includes(label)\n);\n\n// ========================\n// MONTA RESULTADO FINAL\n// ========================\nlet labelsFinal = [...labelsSemQualificacao];\n\n// garante tag do navio se existir campanha válida\nif (campanha && TAGS_NAVIO.includes(campanha) && !labelsFinal.includes(campanha)) {\n  labelsFinal.push(campanha);\n}\n\n// adiciona nova qualificação\nif (!labelsFinal.includes(novaQualificacao)) {\n  labelsFinal.push(novaQualificacao);\n}\n\nreturn [\n  {\n    json: {\n      qualificacao_bruta: qualificacaoBruta,\n      nova_qualificacao: novaQualificacao,\n      campanha,\n      labels_atuais: labelsLimpas,\n      labels_sem_qualificacao: labelsSemQualificacao,\n      labels_final: labelsFinal,\n      labels: labelsFinal\n    }\n  }\n];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[-4896,2832],"id":"3c37a104-1547-415d-8f06-a6f9ab430320","name":"Code in JavaScript1"}],"connections":{"HTTP Request15":{"main":[[{"node":"Pega id do contato6","type":"main","index":0}]]},"HTTP Request14":{"main":[[{"node":"HTTP Request15","type":"main","index":0}]]},"HTTP Request11":{"main":[[{"node":"Code in JavaScript1","type":"main","index":0}]]},"HTTP Request10":{"main":[[{"node":"HTTP Request11","type":"main","index":0}]]},"HTTP Request9":{"main":[[{"node":"Pega id do contato11","type":"main","index":0}]]},"HTTP Request8":{"main":[[{"node":"HTTP Request9","type":"main","index":0}]]},"HTTP Request7":{"main":[[{"node":"Pega id do contato10","type":"main","index":0}]]},"HTTP Request6":{"main":[[{"node":"HTTP Request7","type":"main","index":0}]]},"HTTP Request1":{"main":[[{"node":"Pega id do contato8","type":"main","index":0}]]},"HTTP Request":{"main":[[{"node":"HTTP Request1","type":"main","index":0}]]},"Switch":{"main":[[{"node":"HTTP Request","type":"main","index":0}],[{"node":"HTTP Request6","type":"main","index":0}],[{"node":"HTTP Request8","type":"main","index":0}],[{"node":"HTTP Request14","type":"main","index":0}],[{"node":"HTTP Request10","type":"main","index":0}]]},"When Executed by Another Workflow":{"main":[[{"node":"Code in JavaScript","type":"main","index":0}]]},"Get a row1":{"main":[[{"node":"Update a row1","type":"main","index":0}]]},"Update a row1":{"main":[[{"node":"Switch","type":"main","index":0}]]},"Switch1":{"main":[[{"node":"Atribui tag2","type":"main","index":0}],[{"node":"Atribui tag1","type":"main","index":0}],[{"node":"Atribui tag","type":"main","index":0}]]},"Atribui tag":{"mai