on.urlChatwoot }}/api/v1/accounts/{{ $('start').item.json.accountId }}/conversations","sendHeaders":true,"headerParameters":{"parameters":[{"name":"api_access_token","value":"={{ $('start').item.json.tokenChatwoot }}"}]},"sendBody":true,"bodyParameters":{"parameters":[{"name":"inbox_id","value":"={{ $('Vendedor').item.json.inbox }}"},{"name":"contact_id","value":"={{ $('Busca conversa').item.json.payload[0].meta.sender.id }}"},{"name":"assignee_id","value":"={{ $('Vendedor').item.json.id }}"}]},"options":{}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[-2464,1344],"id":"3705f2c4-2ef7-4ba9-9d45-384be62d86a3","name":"Cria conversa1"},{"parameters":{"jsCode":"// Define o fuso horário (Brasil/São Paulo)\nconst agora = $now.setZone('America/Sao_Paulo');\n\n// --- CONFIGURAÇÃO ---\nconst horaInicio = 9;   // Abre às 09:00\nconst horaFim = 19;     // Fecha às 19:00 (inclui até 18:59)\n\n// Obtém dados atuais\nconst diaSemana = agora.weekday; // 1=Seg, 2=Ter... 6=Sáb, 7=Dom\nconst horaAtual = agora.hour;\n\n// --- LÓGICA ---\n// 1. Verifica se é Segunda(1) a Sexta(5)\nconst ehDiaUtil = diaSemana >= 1 && diaSemana <= 5;\n\n// 2. Verifica horário: Maior ou igual a 9 E Menor que 19\n// (Menor que 19 pega todo o período das 18h, ex: 18:59)\nconst ehHorario = horaAtual >= horaInicio && horaAtual < horaFim;\n\n// Resultado final (true ou false)\nconst estaAberto = ehDiaUtil && ehHorario;\n\n// Retorno no padrão do n8n\nreturn {\n  json: {\n    dentroDoHorario: estaAberto\n  }\n}"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[-1792,1344],"id":"8814b108-a105-4419-a478-c47341e14792","name":"Code in JavaScript2"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"0513371b-3a96-4e38-aecb-2146ef2734b8","leftValue":"={{ $json.dentroDoHorario }}","rightValue":"={{ $json.dentroDoHorario }}","operator":{"type":"boolean","operation":"true","singleValue":true}}],"combinator":