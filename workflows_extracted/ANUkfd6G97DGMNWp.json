─\nconst ALIASES_POR_SLUG = {\n  'roberto_carlos_2026':           ['roberto carlos', 'tributo roberto carlos', 'rc 2026'],\n  'chitaozinho_xororo_2026':       ['chitaozinho', 'chitãozinho', 'xororo', 'xororó', 'ch&x'],\n  'vumbora_pro_mar_2026':          ['vumbora', 'bell marques', 'pro mar 2026'],\n  'cabare_2026':                   ['cabare', 'cabaré', 'leonardo cantor'],\n  'reveillon_alto_mar':            ['reveillon em alto-mar', 'réveillon em alto-mar', 'reveillon 2026', 'reveillon 2027'],\n  'embaixador_gusttavo_lima':      ['embaixador', 'gusttavo lima'],\n  '89_rock_boat':                  ['89 rock', 'rock boat', '89rock'],\n  'dominguinho_alto_mar':          ['dominguinho', 'joão gomes', 'mestrinho'],\n  'wesley_safadao_ws_on_board':    ['wesley safadão', 'wesley safadao', 'ws on board', 'safadão'],\n  'daniel_o_amor_que_nao_tem_fim': ['daniel o amor', 'navio daniel', 'amor que não tem fim']\n};\n\n// Prioridade (maior = mais forte). Confirmada paulotodo 2026-05-11.\nconst PRIORIDADE_ORIGEM = { utm:5, lead_explicito:4, chatwoot_attr:3, nlu:2, manual:1 };\n\nconst norm = (s) => (s || '').toString().toLowerCase()\n  .normalize('NFD').replace(/[\\u0300-\\u036f]/g, '');\n\nfunction detectarPorRegex(texto) {\n  const t = norm(texto);\n  if (!t) return null;\n  for (const slug of Object.keys(ALIASES_POR_SLUG)) {\n    for (const a of ALIASES_POR_SLUG[slug]) {\n      if (t.includes(norm(a))) return slug;\n    }\n  }\n  return null;\n}\n\nfunction detectarPorUtm(t) {\n  const utm = (t.utm_content || t.utm_campaign || '').toString().toLowerCase();\n  if (!utm) return null;\n  if (Object.keys(ALIASES_POR_SLUG).includes(utm)) return utm;\n  return detectarPorRegex(utm);\n}\n\nconst focalPrev      = leadDb.navio_focal || null;\nconst origemPrev     = leadDb.navio_focal_origem || null;\nconst prioridadePrev = origemPrev ? (PRIORIDADE_ORIGEM[origemPrev] || 0) : 0;\n\nconst detUtm   = detectarPorUtm(trigger);\nconst detRegex = detectarPorRegex(trigger.mensagem);\n\nlet focalNovo  = focalPrev;\nlet origemNova = origemPrev;\nlet mudou      = false;\n\nif (detUtm) {\n  if (detUtm !== focalPrev || PRIORIDADE_ORIGEM.utm > prioridadePrev) {\n    focalNovo  = detUtm;\n    origemNova = 'utm';\n    mudou      = (detUtm !== focalPrev);\n  }\n} else if (detRegex) {\n  // Sobrescreve quando: focal não existe; ou origem prev <= nlu (ou seja, prev é nlu/manual/null);\n  // ou lead mudou explicitamente de tema (slug diferente).\n  const prioridadeNova = PRIORIDADE_ORIGEM.nlu;\n  if (!focalPrev || prioridadePrev <= prioridadeNova || detRegex !== focalPrev) {\n    focalNovo  = detRegex;\n    origemNova = 'nlu';\n    mudou      = (detRegex !== focalPrev);\n  }\n}\n\nconst navio_focal_set_at = mudou\n  ? new Date().toISOString()\n  : (leadDb.navio_focal_set_at || null);\n\nreturn [{ json: {\n  etapa,\n  pausado: false,\n  lead_data: leadDb,\n  trigger,\n  chatid:          trigger.chatid,\n  mensagem:        trigger.mensagem,\n  urlchatwoot:     trigger.urlchatwoot,\n  account_id:      trigger.account_id,\n  conversation_id: trigger.conversation_id,\n  chatwoottoken:   trigger.chatwoottoken,\n  contact_id:      trigger.contact_id,\n  navio_focal:        focalNovo,\n  navio_focal_origem: origemNova,\n  navio_focal_set_at: navio_focal_set_at,\n  navio_focal_changed: mudou\n} }];"},"id":"08a91ac3-cfe3-4507-a8e6-d10afbd9b873","name":"Determine Route","type":"n8n-nodes-base.code","typeVersion":2,"position":[4640,4768]},{"parameters":{"operation":"get","tableId":"={{ $('Extract Message Data').first().json.tabela_whatsapp }}","filters":{"conditions":[{"keyName":"=Telefone","keyValue":"={{ $('Extract Message Data').first().json.chatid }}"}]}},"id":"1a7b2633-2383-4615-a691-15b4119c40f3","name":"Get Lead Status","type":"n8n-nodes-base.supabase","typeVersion":1,"position":[1504,4976],"alwaysOutputData":true,"retryOnFail":true,"credentials":{"supabaseApi":{"id":"AEkTABg8nAlKbpWh","name":"Supabase - Banco de Dados"}}},{"parameters":{"workflowId":{"__rl":true,"valu