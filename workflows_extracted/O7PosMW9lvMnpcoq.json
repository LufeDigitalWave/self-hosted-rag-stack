ificacao = null;\n\nif (qualificacaoNormalizada === 'baixa' || qualificacaoNormalizada === 'baixa_qualificacao') {\n  novaQualificacao = 'baixa_qualificacao';\n} else if (qualificacaoNormalizada === 'media' || qualificacaoNormalizada === 'media_qualificacao') {\n  novaQualificacao = 'media_qualificacao';\n} else if (qualificacaoNormalizada === 'alta' || qualificacaoNormalizada === 'alta_qualificacao') {\n  novaQualificacao = 'alta_qualificacao';\n}\n\n// ========================\n// VALIDA\n// ========================\nif (!novaQualificacao || !TAGS_QUALIFICACAO.includes(novaQualificacao)) {\n  throw new Error(`Qualificação inválida: ${qualificacaoBruta}`);\n}\n\n// ========================\n// PEGA LABELS ATUAIS\n// ========================\nconst labelsAtuais = Array.isArray(data.labels) ? data.labels : [];\n\n// ========================\n// LIMPA LABELS\n// ========================\nconst labelsLimpas = labelsAtuais\n  .filter(label => typeof label === 'string' && label.trim() !== '')\n  .map(label => label.trim());\n\n// ========================\n// PEGA CAMPANHA/NAVIO\n// ========================\nconst campanha =\n  data.meta?.sender?.custom_attributes?.campanha ||\n  data.payload?.custom_attributes?.campanha ||\n  data.custom_attributes?.campanha ||\n  null;\n\n// ========================\n// REMOVE SÓ QUALIFICAÇÃO ANTIGA\n// ========================\nconst labelsSemQualificacao = labelsLimpas.filter(\n  label => !TAGS_QUALIFICACAO.includes(label)\n);\n\n// ========================\n// MONTA RESULTADO FINAL\n// ========================\nlet labelsFinal = [...labelsSemQualificacao];\n\n// garante tag do navio se existir campanha válida\nif (campanha && TAGS_NAVIO.includes(campanha) && !labelsFinal.includes(campanha)) {\n  labelsFinal.push(campanha);\n}\n\n// adiciona nova qualificação\nif (!labelsFinal.includes(novaQualificacao)) {\n  labelsFinal.push(novaQualificacao);\n}\n\nreturn [\n  {\n    json: {\n      qualificacao_bruta: qualificacaoBruta,\n      nova_qualificacao: novaQualificacao,\n      campanha,\n      labels_atuais: labelsLimpas,\n      labels_sem_qualificacao: labelsSemQualificacao,\n      labels_final: labelsFinal,\n      labels: labelsFinal\n    }\n  }\n];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[-1840,2336],"id":"a65fc54a-c84f-4271-9605-e45202f62975","name":"Code in JavaScript1"}],"connections":{"HTTP Request15":{"main":[[{"node":"Pega id do contato6","type":"main","index":0}]]},"HTTP Request14":{"main":[[{"node":"HTTP Request15","type":"main","index":0}]]},"HTTP Request11":{"main":[[{"node":"Code in JavaScript1","type":"main","index":0}]]},"HTTP Request10":{"main":[[{"node":"HTTP Request11","type":"main","index":0}]]},"HTTP Request9":{"main":[[{"node":"Pega id do contato11","type":"main","index":0}]]},"HTTP Request8":{"main":[[{"node":"HTTP Request9","type":"main","index":0}]]},"HTTP Request7":{"main":[[{"node":"Pega id do contato10","type":"main","index":0}]]},"HTTP Request6":{"main":[[{"node":"HTTP Request7","type":"main","index":0}]]},"HTTP Request1":{"main":[[{"node":"Pega id do contato8","type":"main","index":0}]]},"HTTP Request":{"main":[[{"node":"HTTP Request1","type":"main","index":0}]]},"Switch":{"main":[[{"node":"HTTP Request","type":"main","index":0}],[{"node":"HTTP Request6","type":"main","index":0}],[{"node":"HTTP Request8","type":"main","index":0}],[{"node":"HTTP Request14","type":"main","index":0}],[{"node":"HTTP Request10","type":"main","index":0}]]},"When Executed by Another Workflow":{"main":[[{"node":"Code in JavaScript","type":"main","index":0}]]},"Get a row1":{"main":[[{"node":"Update a row1","type":"main","index":0}]]},"Update a row1":{"main":[[{"node":"Switch","type":"main","index":0}]]},"Switch1":{"main":[[{"node":"Atribui tag2","type":"main","index":0}],[{"node":"Atribui tag1","type":"main","index":0}],[{"node":"Atribui tag","type":"main","index":0}]]},"Atribui tag":{"main":[[{"node":"Pega id do contato4","type":"main","index":0}]]},"Atribui tag1":{"main":[[{"n