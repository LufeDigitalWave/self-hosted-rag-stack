"convertFieldsToString":true},"options":{"waitForSubWorkflow":true}},"id":"ddd990f1-13fd-4089-a47d-1afe3f1606aa","name":"Exec_WF_SalvarLead1","type":"n8n-nodes-base.executeWorkflow","typeVersion":1.2,"position":[-8576,2544],"retryOnFail":true,"maxTries":2,"waitBetweenTries":1000,"notesInFlow":false,"onError":"continueRegularOutput","notes":"[EXEC_SALVAR_FIXES_V1] 20260425-204050\n[EXEC_SALVAR_FIXES_V2] 20260425-213039"},{"parameters":{"sessionIdType":"customKey","sessionKey":"={{ $('Workflow Trigger').first().json.chatid }}_{{ $('Workflow Trigger').first().json.tipo_fluxo }}","tableName":"promo","contextWindowLength":100},"type":"@n8n/n8n-nodes-langchain.memoryPostgresChat","typeVersion":1.3,"position":[-9712,2768],"id":"04c25f4b-b78d-4dc3-9103-f5048fcba5d9","name":"memory","credentials":{"postgres":{"id":"TTrqj0rnakiukRd7","name":"Postgres account"}}},{"parameters":{"description":"Busca na base de conhecimento DomainAssistant (RAG híbrido: pgvector + BM25 + rerank).\n  Use SEMPRE antes de afirmar qualquer fato sobre navio, experience resource, pacote,\n  pagamento, FAQ, roteiro ou objeção. Retorna trechos curados com title,\n  content, topic, subtopic e score. Se tem_resultado=false, NÃO invente —\n  responda com uma pergunta de qualificação.","workflowId":{"__rl":true,"value":"Pl7vzyo55h7KCHHeKZyE2","mode":"list","cachedResultUrl":"/workflow/Pl7vzyo55h7KCHHeKZyE2","cachedResultName":"WF_Busca_KB"},"workflowInputs":{"mappingMode":"defineBelow","value":{"top_k":"={{ /*n8n-auto-generated-fromAI-override*/ $fromAI('top_k', `quantos chunks retornar (padrão 3)`, 'number') }}","query":"={{ /*n8n-auto-generated-fromAI-override*/ $fromAI('query', `texto da pergunta do lead`, 'string') }}","filters":"={{ $fromAI('filters', `filtros opcionais de busca`, 'json', { \"topic\": null}) }}"},"matchingColumns":[],"schema":[{"id":"query","displayName":"query","required":false,"defaultMatch":false,"display":true,"canBeUsedToMatch":true,"type":"string","removed":false},{"id":"filters","displayName":"filters","required":false,"defaultMatch":false,"display":true,"canBeUsedToMatch":true,"type":"object","removed":false},{"id":"top_k","displayName":"top_k","required":false,"defaultMatch":false,"display":true,"canBeUsedToMatch":true,"type":"number","removed":false}],"attemptToConvertTypes":false,"convertFieldsToString":false}},"id":"f26fb671-052b-438b-997a-3976bd566d38","name":"consultar_base_conhecimento","type":"@n8n/n8n-nodes-langchain.toolWorkflow","typeVersion":2.2,"position":[-9584,2768]},{"parameters":{"description":"=Busca metadados de mídia de uma experience resource MSC Divina na tabela cabin_media e retorna { encontrado, asset_url, whatsapp_id, label, categoria, variante }. O campo asset_url é a URL pública da foto da experience resource.\nQUANDO USAR: sempre que você for emitir enviar_foto_cabine=true (o lead pediu foto/imagem da experience resource nesta mensagem — \"me manda a foto\", \"posso ver a experience resource?\", \"tem imagem?\"). Chamar ANTES de montar a resposta para popular o campo asset_url do JSON de saída. \n\nENTRADA:\n  - categoria (string, obrigatório): um dos 9 valores — cabines__interna, cabines__interna_superior,  cabines__janela, cabines__varanda, cabines__varanda_superior, cabines__varanda_experience, cabines__suite_janela_experience, cabines__suite_varanda_experience, cabines__yacht_club. \n  - variante (string, obrigatório): experience | premium | superior | null. Use experience para experience resource *_experience; superior para *_superior; null para as demais (interna, janela, varanda, yacht_club).\n  - conta (string, obrigatório): injetada automaticamente pelo sistema ({{ $('Workflow Trigger').first().json.origem }}) — NÃO inventar. Valores válidos: _whatsapp | _formulario | bdr.\n\nNÃO chamar: quando enviar_foto_cabine=false ou quando o lead não pediu foto explicitamente.","workflowId":{"__rl":true,"value":"qtNIPt2NHtH3oj7viT2Rq","mode":"list","cachedResultUrl":"/workflow/qtNIPt2NHtH3oj7viT2Rq","cachedResultName":"WF_Get_Cabin_Media"},"workflowInputs":{"mappingMode":"defineBelow","value":{"categoria":"={{ /*n8n-auto-generated-fromAI-override*/ $fromAI('categoria', ``, 'string') }}","variante":"={{ /*n8n-auto-generated-fromAI-override*/ $fromAI('variante', ``, 'string') }}","conta":"=_{{ $('Workflow Trigger').first().json.origem }}"},"matchingColumns":[],"schema":[{"id":"categoria","displayName":"categoria","required":false,"defaultMatch":false,"display":true,"canBeUsedToMatch":true,"type":"string","removed":false},{"id":"variante","displayName":"variante","required":false,"defaultMatch":false,"display":true,"canBeUsedToMatch":true,"type":"string","removed":false},{"id":"conta","displayName":"conta","required":false,"defaultMatch":false,"display":true,"canBeUsedToMatch":true,"type":"string","removed":false}],"attemptToConvertTypes":false,"convertFieldsToString":false}},"type":"@n8n/n8n-nodes-langchain.toolWorkflow","typeVersion":2.2,"position":[-9456,2768],"id":"68e81e9b-32c2-4955-ac56-783574a7180f","name":"buscar_midia_cabine"},{"parameters":{"jsCode":"// [PROMOTE_ETAPA_V1] v3 — derivacao deterministica de Etapa com GATE FACTUAL + preservacao\n// Decisao Paulo 2026-04-25:\n//   - Semantica GLOBAL (e1..e7 regua unica).\n//   - ANTI_REGRESSAO_ESTRITA (persistido > derivado preserva ambos).\n//   - GATE FACTUAL: e4 (negociacao) so dispara se Navio + QtdPessoas presentes (obrigatorios).\n//     Se TODOS os 4 (Nome+Navio+QtdPessoas+jaFezCruzeiro) preenchidos, ELEVA para (negociacao, e4)\n//     mesmo que LLM tenha emitido sub-estado regressivo (ex.: par (negociacao, e3)).\n//     Se obrigatorios faltam, CAP em qualificacao independente do que LLM mandar.\n//   - v3: PRESERVACAO. Quando o LLM emite null/'null'/'' em campo que o leadData tem com valor real,\n//     o Promotor injeta o valor persistido de volta no acoes.salvar_lead. Defesa contra alucinacao\n//     por omissao (LLM \"esquece\" de copiar QtdPessoas mas o lead ja informou).\n//     hasValue() e pick() ignoram strings lixo (\"null\",\"undefined\",vazio).\n\nconst SUB_TO_ETAPA = Object.freeze({\n  e1: 'qualificacao', e2: 'qualificacao', e3: 'qualificacao',\n  e35: 'qualificacao', 'e3.5': 'qualificacao',\n  e4: 'negociacao',\n  e5: 'pagamento', e6: 'pagamento', e7: 'pagamento',\n});\nconst RANK = Object.freeze({ qualificacao: 1, negociacao: 2, pagamento: 3, handoff: 4 });\n\n// extracted = output do node imediatamente anterior (Extract_JSON*); evita\n// referencia por nome que falha em n8n quando ha variantes (Extract JSON / Extract_JSON / Extract_JSON1).\nconst extracted = ($input && $input.first && $input.first().json) || {};\n\n// leadData = Get Lead State (existe como 'Get Lead State' ou 'Get Lead State1' dependendo do caller).\n// Fallback silencioso quando o nome nao bate, sem quebrar o fluxo.\nfunction safeNode(name) {\n  try {\n    const ref = $(name);\n    if (ref && ref.first && ref.first().json) return ref.first().json;\n  } catch (e) { /* node nao existe neste contexto */ }\n  return null;\n}\nconst leadData = safeNode('Get Lead State') || safeNode('Get Lead State1') || {};\n\nconst salvarLead = (extracted.acoes && extracted.acoes.salvar_lead) || {};\n\n// ── helpers ────────────────────────────────────────────────────────────────\nfunction isJunkValue(v) {\n  if (v === null || v === undefined) return true;\n  if (typeof v === 'string') {\n    const t = v.trim().toLowerCase();\n    return t === '' || t === 'null' || t === 'undefined' || t === 'nan';\n  }\n  return false;\n}\nfunction hasValue(v) {\n  if (isJunkValue(v)) return false;\n  if (typeof v === 'number') return !Number.isNaN(v) && v > 0;\n  if (typeof v === 'boolean') return true;\n  return !!v;\n}\n// pick: retorna o primeiro valor REAL (nao-junk). Robusto contra strings \"null\",\"undefined\" do banco.\nfunction pick(...vals) { for (const v of vals) if (!isJunkValue(v)) return v; return undefined; }\nconst ETAPA_MIN_SUB = { qualificacao: 'e1', negociacao: 'e4', pagamento: 'e5', handoff: null };\n\nlet subProposto = String(salvarLead.em_qual_etapa ?? '').trim().toLowerCase();\nif (subProposto === 'e3.5') subProposto = 'e35';\nconst subPersistido = String(leadData.em_qual_etapa ?? '').trim().toLowerCase();\nconst subFinal = SUB_TO_ETAPA[subProposto] !== undefined ? subProposto : subPersistido;\n\nconst etapaLlm     = String(salvarLead.Etapa ?? salvarLead.etapa ?? '').trim().toLowerCase();\nconst etapaPersist = String(leadData.Etapa   ?? leadData.etapa   ?? '').trim().toLowerCase();\n\n// ── checklist de qualificacao (extrai dos 2 lados, salvar_lead vence) ──────\nconst navio = pick(salvarLead.Navio, salvarLead.navio, leadData.Navio, leadData.navio);\nconst qtd   = pick(salvarLead.QtdPessoas, salvarLead.qtd_pessoas, salvarLead.qtdPessoas, leadData.QtdPessoas, leadData.qtd_pessoas);\nconst nome  = pick(salvarLead.Nome, salvarLead.nome, leadData.Nome, leadData.nome);\nconst jaFez = pick(salvarLead.ja_fez_cruzeiro, salvarLead.jaFezCruzeiro, leadData.ja_fez_cruzeiro, leadData.jaFezCruzeiro);\n\nconst obrigatoriosOk = hasValue(navio) && hasValue(qtd);\n// jaFez aceita true/false explicito (nao confunde com missing); rejeita strings \"null\"/\"undefined\"\nconst jaFezDefinido = !isJunkValue(jaFez);\nconst todosOk = obrigatoriosOk && hasValue(nome) && jaFezDefinido;\n\nlet etapaFinal, motivo, subOut;\nif (etapaLlm === 'handoff') {\n  etapaFinal = 'handoff';\n  subOut = subFinal || subPersistido || 'e1';\n  motivo = 'LLM_HANDOFF_DECLARADO';\n} else {\n  const etapaDerivada = SUB_TO_ETAPA[subFinal] || SUB_TO_ETAPA[subPersistido] || 'qualificacao';\n\n  // GATE 1: Anti-regressao estrita (persistido > derivado/LLM)\n  const rankPersist = RANK[etapaPersist] || 0;\n  const rankDeriv   = RANK[etapaDerivada] || 0;\n  const rankLlm     = RANK[etapaLlm] || 0;\n  if (etapaPersist !== 'handoff' && rankPersist > Math.max(rankDeriv, rankLlm)) {\n    etapaFinal = etapaPersist;\n    subOut = subPersistido || subFinal || 'e1';\n    motivo = `ANTI_REGRESSAO_ESTRITA (persistida=${etapaPersist}/${subPersistido} > derivada=${etapaDerivada}/${subFinal}, LLM=${etapaLlm})`;\n  } else if (!obrigatoriosOk) {\n    // GATE 2: Bloqueio factual — sem Navio+QtdPessoas, nada avanca alem de qualificacao.\n    etapaFinal = 'qualificacao';\n    // Limita sub-estado a {e1..e3,e35,e3.5}; se LLM/derivada quis subir, mantem em e3 como teto.\n    const subParaQualif = SUB_TO_ETAPA[subFinal] === 'qualificacao' ? subFinal : 'e3';\n    subOut = subParaQualif || 'e1';\n    const faltam = [];\n    if (!hasValue(navio)) faltam.push('Navio');\n    if (!hasValue(qtd))   faltam.push('QtdPessoas');\n    motivo = `GATE_FACTUAL_BLOQUEIO (obrigatorios ausentes: ${faltam.join(',')})`;\n  } else if (todosOk) {\n    // GATE 3: Promocao factual — todos os campos OK eleva para (negociacao, e4)\n    // Excecao: se persistido ja esta em pagamento (ou superior), mantem.\n    const etapaCandidata = (rankPersist > 2) ? etapaPersist : 'negociacao';\n    etapaFinal = etapaCandidata;\n    subOut = (rankPersist > 2)\n      ? (subPersistido || ETAPA_MIN_SUB[etapaPersist] || 'e5')\n      : 'e4';\n    motivo = `GATE_FACTUAL_PROMOCAO (todos campos OK -> ${etapaFinal}/${subOut} | LLM=${etapaLlm}/${subProposto})`;\n  } else {\n    // FLUXO PADRAO: max-ascending entre Etapa LLM e etapa derivada do sub-estado\n    const etapaTopo = (rankLlm > rankDeriv) ? etapaLlm : etapaDerivada;\n    etapaFinal = etapaTopo;\n    if (etapaTopo === etapaDerivada) {\n      subOut = subFinal || 'e1';\n    } else {\n      // LLM avancou Etapa, sub-estado regressivo: eleva sub para minimo da etapa LLM\n      subOut = ETAPA_MIN_SUB[etapaTopo] || subFinal || 'e1';\n    }\n    if (etapaLlm && etapaLlm !== etapaFinal) {\n      motivo = `LLM_DIVERGENCIA (LLM=${etapaLlm}/${subProposto} -> final=${etapaFinal}/${subOut})`;\n    } else if (subFinal !== subOut) {\n      motivo = `MAX_ASCENDING (LLM Etapa=${etapaLlm} venceu sub=${subProposto} -> ${etapaFinal}/${subOut})`;\n    } else {\n      motivo = 'CANONICO';\n    }\n  }\n}\n\n// PRESERVACAO v3: para cada campo do checklist, se LLM mandou junk mas leadData tem valor REAL, injeta.\n// Defende contra alucinacao por omissao.\nfunction preserve(slv, ldv) {\n  if (isJunkValue(slv) && !isJunkValue(ldv)) return ldv;\n  return slv;\n}\nconst slPreservado = {\n  ...salvarLead,\n  Nome:               preserve(salvarLead.Nome,                leadData.Nome),\n  Navio:              preserve(salvarLead.Navio,               leadData.Navio),\n  QtdPessoas:         preserve(salvarLead.QtdPessoas,          leadData.QtdPessoas),\n  Email:              preserve(salvarLead.Email,               leadData.Email),\n  Estilo:             preserve(salvarLead.Estilo,              leadData.estilo ?? leadData.Estilo),\n  ja_fez_cruzeiro:    isJunkValue(salvarLead.ja_fez_cruzeiro) ? leadData.ja_fez_cruzeiro : salvarLead.ja_fez_cruzeiro,\n  Etapa: etapaFinal,\n  em_qual_etapa: subOut,\n};\nconst acoesCorrigido = {\n  ...(extracted.acoes || {}),\n  salvar_lead: slPreservado,\n};\n\nconsole.log(`[PROMOTE_ETAPA] motivo=${motivo} | LLM=${etapaLlm}/${subProposto} | persist=${etapaPersist}/${subPersistido} | final=${etapaFinal}/${subOut}`);\n\nreturn [{\n  json: {\n    ...extracted,\n    acoes: acoesCorrigido,\n    etapa_saida: etapaFinal,\n    em_qual_etapa_saida: subOut,\n    promote_motivo: motivo,\n  },\n}];\n"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[-9024,2544],"id":"829f7556-7010-4fbf-a66f-04d40fa3eeae","name":"Promote_Etapa"},{"parameters":{"model":{"__rl":true,"value":"gpt-4.1","mode":"list","cachedResultName":"gpt-4.1"},"options":{"responseFormat":"json_object","temperature":0.8,"timeout":60000,"topP":1}},"id":"4ece2b72-5f9d-4eaf-9b15-e958c07b05fe","name":"OpenAI_Chat_Model1","type":"@n8n/n8n-nodes-langchain.lmChatOpenAi","typeVersion":1.2,"position":[-9904,2768],"retryOnFail":true,"maxTries":3,"waitBetweenTries":1500,"credentials":{"openAiApi":{"id":"K0KQj1MLVoGAPzAv","name":"OpenAi account"}},"disabled":true,"onError":"continueErrorOutput"}],"connections"