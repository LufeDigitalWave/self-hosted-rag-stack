t(yyyy), parseInt(MM) - 1, parseInt(dd), parseInt(HH), parseInt(mm));\n  }\n  \n  function parsePtBr(str) {\n    const meses = {\n      janeiro: 0, fevereiro: 1, março: 2, marco: 2,\n      abril: 3, maio: 4, junho: 5, julho: 6,\n      agosto: 7, setembro: 8, outubro: 9, novembro: 10, dezembro: 11\n    };\n    const clean = str.replace(/^[^,]+,\\s*/, \"\");\n    const m = clean.match(/(\\d{1,2}) de ([^\\s]+) de (\\d{4}), (\\d{2}):(\\d{2})/);\n    if (!m) return null;\n    const [, dd, mesStr, yyyy, HH, MM] = m;\n    const mes = meses[mesStr.toLowerCase()];\n    if (mes === undefined) return null;\n    return new Date(parseInt(yyyy), mes, parseInt(dd), parseInt(HH), parseInt(MM));\n  }\n  \n  function parseData(str) {\n    return parseISO(str) ?? parsePtBr(str);\n  }\n\n  if (!horaMensagemStr || !tempoAtualStr) {\n    return {\n      json: {\n        ...j,\n        error: \"Um dos campos de data está vazio\",\n        _debug: {\n          temHoraMensagem:   Boolean(horaMensagemStr),\n          temTempoAtual:     Boolean(tempoAtualStr),\n          chavesDisponiveis: Object.keys(j)\n        }\n      }\n    };\n  }\n\n  const dataMensagem = parseData(horaMensagemStr);\n  const dataAtual    = parseData(tempoAtualStr);\n\n  if (!dataMensagem || !dataAtual) {\n    return {\n      json: {\n        ...j,\n        error: \"Erro ao interpretar datas\",\n        _debug: {\n          horaMensagemStr,\n          tempoAtualStr,\n          parsedMensagem: String(dataMensagem),\n          parsedAtual:    String(dataAtual)\n        }\n      }\n    };\n  }\n\n  const diffMs      = dataAtual.getTime() - dataMensagem.getTime();\n  const diffHoras   = Math.floor(diffMs / (1000 * 60 * 60));\n  const diffMinutos = Math.floor(diffMs / (1000 * 60)) % 60;\n  const tempoAtual = dataAtual;\n\n  return {\n    json: {\n      ...j,\n      diferencaHoras:   diffHoras,\n      diferencaMinutos: diffMinutos,\n      tempoAtual: tempoAtual,\n      \n    }\n  };\n  \n})\n\nreturn resultadoQuery.sort((a,b)